# Lightman Production Environment
# Copy this file and fill in values before deploying:
#   cp .env.production .env.production.local

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123
POSTGRES_DB=lightman

# Server
PORT=3401
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_STRING_AT_LEAST_32_CHARS
JWT_EXPIRY=24h
CORS_ORIGIN=*

# Host paths (relative to docker-compose.yml)
HOST_STORAGE_PATH=./server/storage
HOST_AGENT_PATH=./agent
