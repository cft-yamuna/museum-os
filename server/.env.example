# LIGHTMAN CMS Server Configuration
# Copy to .env and customize

# Server
NODE_ENV=production
PORT=3001
CORS_ORIGIN=http://localhost:3001

# Database (PostgreSQL)
DATABASE_URL=postgresql://lightman:CHANGE_ME@localhost:5432/lightman

# Authentication
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_STRING_AT_LEAST_32_CHARS
JWT_EXPIRY=24h

# Storage (local filesystem — used when S3 is not configured)
STORAGE_PATH=./storage

# S3-compatible storage (optional — for cloud deployment)
# When S3_ENDPOINT is set, all S3 vars are required.
# Works with Railway Buckets, AWS S3, MinIO, Cloudflare R2, etc.
# S3_ENDPOINT=https://your-bucket.s3.us-west-2.amazonaws.com
# S3_REGION=us-west-2
# S3_BUCKET=lightman-storage
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key

# MQTT (optional - leave empty if not using Mosquitto)
MQTT_URL=mqtt://localhost:1883

# Backups
BACKUP_DIR=./backups
