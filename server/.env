# MUSEUMOS CMS Server Configuration

# Server
NODE_ENV=development
PORT=3401
CORS_ORIGIN=*

# Database (PostgreSQL)
# >>> CHANGE the password below to YOUR postgres password <<<
DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/museumos

# Authentication
JWT_SECRET=museumos-dev-secret-key-change-in-production-32chars
JWT_EXPIRY=24h

# Storage (local filesystem)
STORAGE_PATH=./storage

# MQTT (optional - comment out if not using)
# MQTT_URL=mqtt://localhost:1883

# Backups
BACKUP_DIR=./backups
